    forward <- function(x) {
        x * factor
    }
    
    backward <- function(x) {
        x / factor
    }
    
    list(forward = forward, backward = backward)
}

# Define shift generator
gen_shift <- function(x, offset = 10, ...) {
    forward <- function(x) {
        x + offset
    }
    
    backward <- function(x) {
        x - offset
    }
    
    list(forward = forward, backward = backward)
}

